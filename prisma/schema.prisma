//
// LOANS
//

model Loan {
  id                String        @id @default(uuid())
  workspaceId       String
  workspace         Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  ownerUserId       String?
  ownerUser         User?         @relation("LoanOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  sharedWithUserIds String[]      @default([])
  kind              LoanKind
  source            LoanSource    @default(BANK)
  // Free-form lender display name. For HAND_FORMAL loans this is the
  // contact's name (denormalized so old loans still render if the contact
  // is later archived/renamed); other sources store the bank/NBFC name.
  lender            String
  // For HAND_FORMAL loans: the workspace contact who lent the money.
  // Optional because legacy hand loans (created before contacts existed)
  // only have the free-text `lender` field.
  lenderContactId   String?
  lenderContact     Contact?      @relation("LoanLenderContact", fields: [lenderContactId], references: [id], onDelete: SetNull)
  borrower          String?
  principal         Decimal       @db.Decimal(14, 2)
  outstanding       Decimal       @db.Decimal(14, 2)
  interestRate      Decimal?      @db.Decimal(6, 3)
  gstOnInterest     Decimal?      @db.Decimal(6, 3)
  emiAmount         Decimal?      @db.Decimal(12, 2)
  tenure            Int?
  frequency         LoanFrequency @default(MONTHLY)
  charges           Decimal?      @db.Decimal(12, 2)
  chargeBreakdown   Json?
  accountId         String?
  account           Account?      @relation(fields: [accountId], references: [id], onDelete: SetNull)
  cardId            String?
  card              Card?         @relation("CardEmiLoan", fields: [cardId], references: [id], onDelete: SetNull)
  // Optional virtual loan-account number issued for CREDIT_CARD_LOAN kinds
  // (e.g. HDFC Insta Jumbo Loan AAN). The parent credit card stays usable;
  // EMIs are billed against this separate account number on the same
  // statement cycle as the parent card.
  loanAccountNumber String?
  // Per-loan billing-cycle overrides for CREDIT_CARD_LOAN kinds. When set,
  // they take precedence over the linked card's account.statementDate /
  // gracePeriod when computing nextDueDate. Useful when (a) the linked
  // card doesn't have those fields configured, or (b) the loan's separate
  // AAN bills on a different cycle than the parent card.
  loanStatementDate Int?
  loanGracePeriod   Int?
  isExisting        Boolean       @default(false)
  foreclosedAt      DateTime?
  foreclosureAmt    Decimal?      @db.Decimal(14, 2)
  startedAt         DateTime
  maturityAt        DateTime?
  nextDueDate       DateTime?
  notes             String?
  active            Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  vehicleId String?
  vehicle   Vehicle? @relation("VehicleLoan", fields: [vehicleId], references: [id], onDelete: SetNull)

  transactions Transaction[]
  reminders    InvestmentReminder[] @relation("ReminderLoan")
  goldItems    GoldLoanItem[]

  @@index([workspaceId, active, source])
  @@index([workspaceId, ownerUserId])
  @@index([cardId])
  @@index([workspaceId, lenderContactId])
  @@index([vehicleId])
}

// Gold pledged as collateral for a GOLD loan. Each row is one type of
// item (e.g. "Bangles") with a count and per-piece weight in grams plus
// karat purity. The pledged value isn't tracked here — banks recompute
// it from current gold rates.
model GoldLoanItem {
  id          String   @id @default(uuid())
  loanId      String
  loan        Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  name        String
  quantity    Int      @default(1)
  weightGrams Decimal  @db.Decimal(10, 3)
  purity      Int?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([loanId])
}

//
// INVESTMENTS + REMINDERS
//

model Investment {
  id                     String                @id @default(uuid())
  workspaceId            String
  workspace              Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  ownerUserId            String?
  ownerUser              User?                 @relation("InvestmentOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  sharedWithUserIds      String[]              @default([])
  holderName             String?
  kind                   InvestmentKind
  name                   String
  institution            String?
  amount                 Decimal               @db.Decimal(14, 2)
  currentValue           Decimal?              @db.Decimal(14, 2)
  interestRate           Decimal?              @db.Decimal(6, 3)
  compoundingFrequency   CompoundingFrequency?
  fdStatus               FDStatus?
  startedAt              DateTime
  maturityAt             DateTime?
  notes                  String?
  active                 Boolean               @default(true)
  symbol                 String?
  quantity               Decimal?              @db.Decimal(18, 6)
  purchasePrice          Decimal?              @db.Decimal(14, 4)
  purchaseExchangeRate   Decimal?              @db.Decimal(10, 4)
  dividends              Decimal?              @db.Decimal(14, 2)
  exchange               String?
  currency               String?               @default("INR")
  policyNumber           String?
  policyType             InsurancePolicyType?
  insuranceStatus        InsuranceStatus?      @default(ACTIVE)
  premiumAmount          Decimal?              @db.Decimal(14, 2)
  premiumFrequency       PremiumFrequency?
  sumAssured             Decimal?              @db.Decimal(14, 2)
  nextDueDate            DateTime?
  nominee                String?
  riders                 String?
  /**
   * Structured riders for LIFE policies: { list: [{ name, sumAssured?, notes? }] }.
   * Separate from the legacy free-text `riders` field so we don't lose any
   * historic notes. New UI writes here.
   */
  ridersJson             Json?
  // Life-insurance corporate fields. All nullable — other policy types ignore them.
  policyTermYears        Int?
  premiumPayingTermYears Int?
  maturityValue          Decimal?              @db.Decimal(14, 2)
  bonusAccrued           Decimal?              @db.Decimal(14, 2)
  bonusLastRevisedAt     DateTime?
  /**
   * Kind-specific structured extras (e.g. for GOLD: { type, purity, wastage, making, gst }).
   */
  metadata               Json?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  vehicleId String?
  vehicle   Vehicle? @relation("VehicleInsurance", fields: [vehicleId], references: [id], onDelete: SetNull)

  // Renewal chain for INSURANCE policies — when a renewal issues a new
  // policy number, we create a fresh Investment row and link back to
  // the predecessor here. Deleting the predecessor sets this null so
  // the successor isn't cascade-deleted (the new row is the system of
  // record going forward).
  renewedFromInvestmentId String?
  renewedFrom             Investment?  @relation("InvestmentRenewal", fields: [renewedFromInvestmentId], references: [id], onDelete: SetNull)
  successors              Investment[] @relation("InvestmentRenewal")

  transactions   Transaction[]
  reminders      InvestmentReminder[] @relation("ReminderInvestment")
  insuredMembers InsuredMember[]      @relation("InsuranceMembers")
  claims         InsuranceClaim[]     @relation("InsuranceClaims")

  @@index([workspaceId, kind, active])
  @@index([workspaceId, ownerUserId])
  @@index([vehicleId])
  @@index([renewedFromInvestmentId])
}

model StockWishlist {
  id                String    @id @default(uuid())
  workspaceId       String
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  ownerUserId       String?
  ownerUser         User?     @relation("StockWishlistOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  sharedWithUserIds String[]  @default([])
  symbol            String
  name              String?
  exchange          String?
  targetPrice       Decimal?  @db.Decimal(14, 4)
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([workspaceId])
  @@index([workspaceId, ownerUserId])
}

model InvestmentReminder {
  id                     String                @id @default(uuid())
  workspaceId            String
  workspace              Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  investmentId           String?
  investment             Investment?           @relation("ReminderInvestment", fields: [investmentId], references: [id], onDelete: Cascade)
  insuredMemberId        String?
  insuredMember          InsuredMember?        @relation("ReminderInsuredMember", fields: [insuredMemberId], references: [id], onDelete: Cascade)
  loanId                 String?
  loan                   Loan?                 @relation("ReminderLoan", fields: [loanId], references: [id], onDelete: Cascade)
  leaseScheduleId        String?
  leaseSchedule          LeasePaymentSchedule? @relation("ReminderLeaseSchedule", fields: [leaseScheduleId], references: [id], onDelete: Cascade)
  cardStatementId        String?
  cardStatement          CardStatement?        @relation("ReminderCardStatement", fields: [cardStatementId], references: [id], onDelete: Cascade)
  vehicleDocumentId      String?
  vehicleDocument        VehicleDocument?      @relation("ReminderVehicleDocument", fields: [vehicleDocumentId], references: [id], onDelete: Cascade)
  kind                   ReminderKind
  dueDate                DateTime              @db.Date
  amount                 Decimal?              @db.Decimal(14, 2)
  status                 ReminderStatus        @default(UPCOMING)
  confirmedTransactionId String?               @unique
  confirmedTransaction   Transaction?          @relation("ReminderConfirmation", fields: [confirmedTransactionId], references: [id], onDelete: SetNull)
  skippedReason          String?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  @@index([workspaceId, status, dueDate])
  @@index([investmentId])
  @@index([insuredMemberId])
  @@index([loanId])
  @@index([vehicleDocumentId])
}

model InsuredMember {
  id               String            @id @default(uuid())
  workspaceId      String
  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  investmentId     String
  investment       Investment        @relation("InsuranceMembers", fields: [investmentId], references: [id], onDelete: Cascade)
  contactId        String
  contact          Contact           @relation("InsuredMemberContact", fields: [contactId], references: [id], onDelete: Restrict)
  premiumAmount    Decimal?          @db.Decimal(14, 2)
  premiumFrequency PremiumFrequency?
  sumAssured       Decimal?          @db.Decimal(14, 2)
  coverageStart    DateTime?
  coverageEnd      DateTime?
  active           Boolean           @default(true)
  notes            String?
  // For LIFE policies a member can be a BENEFICIARY instead of the
  // insured. Beneficiary shares are stored as a percentage and the API
  // validates that all BENEFICIARY shares on a policy sum to ≤ 100.
  role             InsuredMemberRole @default(INSURED)
  sharePercent     Decimal?          @db.Decimal(5, 2)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  reminders InvestmentReminder[] @relation("ReminderInsuredMember")
  claims    InsuranceClaim[]     @relation("ClaimInsuredMember")

  @@unique([investmentId, contactId])
  @@index([workspaceId, active])
}

model InsuranceClaim {
  id                String           @id @default(uuid())
  workspaceId       String
  workspace         Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  investmentId      String
  investment        Investment       @relation("InsuranceClaims", fields: [investmentId], references: [id], onDelete: Cascade)
  insuredMemberId   String?
  insuredMember     InsuredMember?   @relation("ClaimInsuredMember", fields: [insuredMemberId], references: [id], onDelete: SetNull)
  vehicleId         String?
  vehicle           Vehicle?         @relation("VehicleClaims", fields: [vehicleId], references: [id], onDelete: SetNull)
  hospitalizationId String?          @unique
  hospitalization   Hospitalization? @relation("HospitalizationClaim", fields: [hospitalizationId], references: [id], onDelete: SetNull)
  claimNumber       String?
  incidentDate      DateTime
  filedAt           DateTime?
  status            ClaimStatus      @default(FILED)
  claimedAmount     Decimal?         @db.Decimal(14, 2)
  approvedAmount    Decimal?         @db.Decimal(14, 2)
  receivedAmount    Decimal?         @db.Decimal(14, 2)
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  transactions Transaction[] @relation("TransactionClaim")

  @@index([workspaceId, status])
  @@index([investmentId])
  @@index([vehicleId])
