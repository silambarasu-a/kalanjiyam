  SALE
}

enum LeaseAssetType {
  CROP_BATCH
  LIVESTOCK_BATCH
}

enum LeaseDirection {
  LEASED_OUT
  LEASED_IN
}

enum LeaseFrequency {
  ONE_TIME
  YEARLY
  CUSTOM_MONTHS
