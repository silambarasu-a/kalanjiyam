generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//
// ENUMS
//

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  SUPER_ADMIN
}

enum TransactionType {
  INCOME
  EXPENSE
  INVESTMENT
  HAND_LOAN
  TRANSFER
}

enum TransactionKind {
  SALARY
  INTEREST
  AGRI_INCOME
  LEASE_INCOME
  OTHER_INCOME
  HOUSEHOLD
  GROCERY
  FARM_DEV
  WAGE
  FEED
  VACCINATION
  INVESTMENT
  LOAN_PAYMENT
  OTHER_EXPENSE
  REFUND
}

enum MemberChargeType {
  NONE
  RECOVERABLE
  GIFT
}

enum MemberChargeStatus {
  OUTSTANDING
  PARTIAL
  SETTLED
  WRITTEN_OFF
}

enum AccountKind {
  BANK
  CASH
  CARD
  WALLET
}

enum CardKind {
  DEBIT
  CREDIT
}

enum CardLimitMode {
  SOLO
  SHARED
}

enum CardNetwork {
  VISA
  MASTERCARD
  RUPAY
  AMEX
  DINERS
  OTHER
}

enum LoanSource {
  BANK
  HAND_FORMAL
  CARD_EMI
}

enum LoanKind {
  PERSONAL
  HOME
  CAR
  GOLD
  BUSINESS
  EDUCATION
  CREDIT_CARD_LOAN
  OTHER
}

enum LoanFrequency {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
}

enum InvestmentKind {
  STOCK
  FD
  RD
  MUTUAL_FUND
  SIP
  INSURANCE
  GOLD
  OTHER
}

enum InvestmentAction {
  BUY
  SELL
}

enum InsurancePolicyType {
  LIFE
  HEALTH
  VEHICLE
  HOME
  TRAVEL
  TERM
  ULIP
  ENDOWMENT
  OTHER
}

enum InsuranceStatus {
  ACTIVE
  LAPSED
  MATURED
  SURRENDERED
  CLAIMED
  RENEWED
}

enum ClaimStatus {
  FILED
  INTIMATED
  UNDER_REVIEW
  APPROVED
  PARTIALLY_APPROVED
  REJECTED
  PAID
  CLOSED
}

enum VehicleKind {
  BIKE
  CAR
  TRACTOR
  TRUCK
  SCOOTER
  OTHER
}

// Drives the unit shown on fuel-fill inputs (litres / units / kg) and
// the per-fill mileage calc. Optional on Vehicle so legacy rows don't
// break — fuel inputs hide when the type is unknown.
enum VehicleFuelType {
  PETROL
  DIESEL
  CNG
  LPG
  ELECTRIC
  HYBRID
  OTHER
}

enum VehicleDisposalKind {
  SOLD
  EXCHANGED
  SCRAPPED
  GIFTED
  TOTAL_LOSS
}

enum VehicleDocumentKind {
  RC
  FC
  PUC
  ROAD_TAX
  INSURANCE_COPY
  OTHER
}

enum InsuredMemberRole {
  INSURED
  BENEFICIARY
}

enum HospitalizationStage {
  PRE
  DURING
  POST
}

enum GoldForm {
  ORNAMENT
  COIN
  BAR
  BISCUIT
  JEWELLERY_MAKING
}

enum NotificationKind {
  PREMIUM_DUE_SOON
  PREMIUM_OVERDUE
  POLICY_RENEWING
  CLAIM_STATUS_CHANGED
  CARD_STATEMENT_DUE
  LOAN_EMI_DUE
  GENERIC
}

enum PremiumFrequency {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
  ONE_TIME
}

enum CompoundingFrequency {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
}

enum FDStatus {
  ACTIVE
  MATURED
  CLOSED
  PREMATURE_WITHDRAWAL
}

enum CropStatus {
  PLANNED
  ACTIVE
  HARVESTED
  CLOSED
}

enum LivestockEventType {
  PURCHASE
  BIRTH
