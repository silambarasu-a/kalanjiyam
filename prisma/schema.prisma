  PENDING
  SETTLED
  CANCELLED
}

enum AreaUnit {
  ACRES
  HECTARES
  CENTS
  SQFT
  SQM
}

enum ReminderKind {
  SIP_BUY
  FD_INTEREST
  INSURANCE_PREMIUM
  LEASE_PAYMENT
  LOAN_EMI
  CARD_STATEMENT
  VEHICLE_DOC_RENEWAL
}

enum ReminderStatus {
  UPCOMING
  CONFIRMED
  SKIPPED
  MISSED
}

//
// IDENTITY
//

model User {
  id                String     @id @default(uuid())
  name              String
  email             String     @unique
  emailVerified     DateTime?
  passwordHash      String
  activeWorkspaceId String?
  activeWorkspace   Workspace? @relation("UserActiveWorkspace", fields: [activeWorkspaceId], references: [id], onDelete: SetNull)
  lastLoginAt       DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  ownedWorkspaces         Workspace[]              @relation("WorkspaceOwner")
  memberships             WorkspaceMember[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  contactProfile          Contact?

  ownedAccounts             Account[]          @relation("AccountOwner")
  ownedCards                Card[]             @relation("CardOwner")
  ownedLoans                Loan[]             @relation("LoanOwner")
  ownedInvestments          Investment[]       @relation("InvestmentOwner")
  ownedStockWishlist        StockWishlist[]    @relation("StockWishlistOwner")
  transactions              Transaction[]      @relation("TransactionAuthor")
  createdTransactions       Transaction[]      @relation("TransactionCreatedBy")
  editedTransactions        Transaction[]      @relation("TransactionEditedBy")
  wagePayments              WagePayment[]
  wageSettlements           WageSettlement[]
  receivedAdvanceRepayments AdvanceRepayment[] @relation("AdvanceRepaymentReceiver")
  reversedAdvanceRepayments AdvanceRepayment[] @relation("AdvanceRepaymentReverser")
  transfers                 Transfer[]         @relation("TransferAuthor")
  auditLogs                 AuditLog[]
  sentWorkspaceInvites      WorkspaceInvite[]  @relation("WorkspaceInviteInviter")
  notifications             Notification[]
  uploadedAttachments       Attachment[]       @relation("AttachmentUploader")
  archivedAttachments       Attachment[]       @relation("AttachmentArchiver")

  @@index([email])
}

model Workspace {
  id                        String   @id @default(uuid())
  name                      String
  slug                      String?  @unique
  ownerUserId               String
  owner                     User     @relation("WorkspaceOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  // How many days a non-card transaction stays editable from its date.
  // Card-account transactions follow a different rule (locked once their
  // billing period closes into a CardStatement). 0 disables the window.
  transactionEditWindowDays Int      @default(30)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  members             WorkspaceMember[]
  invites             WorkspaceInvite[]
  activeForUsers      User[]               @relation("UserActiveWorkspace")
  contacts            Contact[]
  categories          Category[]
  accounts            Account[]
  cards               Card[]
  cardStatements      CardStatement[]
  transactions        Transaction[]
  transactionSplits   TransactionSplit[]
  transfers           Transfer[]
  memberCharges       MemberCharge[]
  lands               Land[]
  crops               Crop[]
  livestock           Livestock[]
  leases              Lease[]
  workers             Worker[]
  advanceRepayments   AdvanceRepayment[]
  loans               Loan[]
  investments         Investment[]
  investmentReminders InvestmentReminder[]
  insuredMembers      InsuredMember[]
  insuranceClaims     InsuranceClaim[]
  vehicles            Vehicle[]
  vehicleDocuments    VehicleDocument[]
  hospitalizations    Hospitalization[]
  events              Event[]
  notifications       Notification[]
  attachments         Attachment[]
  stockWishlist       StockWishlist[]
  auditLogs           AuditLog[]

  @@index([ownerUserId])
}

model WorkspaceMember {
  id          String        @id @default(uuid())
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        WorkspaceRole
  permissions Json          @default("{}")
  /**
   * Per-member email-notification preferences. Shape:
   * { enabled: boolean, kinds: NotificationKind[] }
   * Default = opted in for all kinds; users opt out from /settings.
   * The server-side `shouldEmail()` also treats unset/missing `enabled`
   * as opted-in, so this default + that fallback both point the same way.
   */
  emailPrefs  Json          @default("{\"enabled\":true}")
  invitedAt   DateTime      @default(now())
  acceptedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId, role])
}

model WorkspaceInvite {
  id              String        @id @default(uuid())
  workspaceId     String
  workspace       Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  email           String
  role            WorkspaceRole
  permissions     Json          @default("{}")
  tokenHash       String        @unique
  expiresAt       DateTime
  acceptedAt      DateTime?
  cancelledAt     DateTime?
  invitedByUserId String
  invitedByUser   User          @relation("WorkspaceInviteInviter", fields: [invitedByUserId], references: [id], onDelete: Restrict)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([workspaceId, acceptedAt])
  @@index([email, acceptedAt])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Contact {
  id           String    @id @default(uuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name         String
  relationship String?
  dob          DateTime? @db.Date
  userId       String?   @unique
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  notes        String?
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  ownedAccounts      Account[]          @relation("AccountContactOwner")
  ownedCards         Card[]             @relation("CardContactOwner")
  beneficiaryTxns    Transaction[]      @relation("TransactionBeneficiary")
  transactionSplits  TransactionSplit[] @relation("ContactSplits")
  sentTransfers      Transfer[]         @relation("TransferFromContact")
  receivedTransfers  Transfer[]         @relation("TransferToContact")
  memberCharges      MemberCharge[]
  lessorLeases       Lease[]            @relation("LeaseLessor")
  lesseeLeases       Lease[]            @relation("LeaseLessee")
  lenderLoans        Loan[]             @relation("LoanLenderContact")
  insuredMemberships InsuredMember[]    @relation("InsuredMemberContact")
  ownedVehicles      Vehicle[]          @relation("VehicleOwner")
  vehiclesBought     Vehicle[]          @relation("VehicleDisposalBuyer")
  hospitalizations   Hospitalization[]  @relation("HospitalizationPatient")

  @@index([workspaceId, active])
}

//
// MONEY
//

model Account {
  id                String      @id @default(uuid())
  workspaceId       String
  workspace         Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  ownerUserId       String?
  ownerUser         User?       @relation("AccountOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  ownerContactId    String?
  ownerContact      Contact?    @relation("AccountContactOwner", fields: [ownerContactId], references: [id], onDelete: SetNull)
  sharedWithUserIds String[]    @default([])
  kind              AccountKind
  name              String
  openingBalance    Decimal     @default(0) @db.Decimal(14, 2)
  creditLimit       Decimal?    @db.Decimal(14, 2)
  statementDate     Int?
  gracePeriod       Int?
  // For CREDIT companion accounts: pre-existing bill due date + amount
  // captured at onboarding. Used when the user adds a card that already
  // has a generated statement due before the regular cycle math takes
  // over. Cleared/updated by the user manually after the bill is paid.
  nextBillDue       DateTime?
  nextBillAmount    Decimal?    @db.Decimal(14, 2)
  active            Boolean     @default(true)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  transactions   Transaction[]
  loans          Loan[]
  transfersFrom  Transfer[]      @relation("TransferFrom")
  transfersTo    Transfer[]      @relation("TransferTo")
  cardsAsParent  Card[]          @relation("CardParentAccount")
  linkedCard     Card?           @relation("CardAccount")
  cardStatements CardStatement[]

  @@index([workspaceId, active])
  @@index([workspaceId, ownerUserId])
  @@index([workspaceId, ownerContactId])
}

model Card {
  id                String        @id @default(uuid())
  workspaceId       String
  workspace         Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  ownerUserId       String?
  ownerUser         User?         @relation("CardOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  ownerContactId    String?
  ownerContact      Contact?      @relation("CardContactOwner", fields: [ownerContactId], references: [id], onDelete: SetNull)
  sharedWithUserIds String[]      @default([])
  name              String
  kind              CardKind
  network           CardNetwork   @default(OTHER)
  supportsUpi       Boolean       @default(false)
  last4             String?
  parentAccountId   String?
  parentAccount     Account?      @relation("CardParentAccount", fields: [parentAccountId], references: [id], onDelete: SetNull)
  accountId         String?       @unique
  account           Account?      @relation("CardAccount", fields: [accountId], references: [id], onDelete: SetNull)
  limitMode         CardLimitMode @default(SOLO)
  parentCardId      String?
  parentCard        Card?         @relation("CardParentCard", fields: [parentCardId], references: [id], onDelete: SetNull)
  childCards        Card[]        @relation("CardParentCard")
  active            Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  transactions Transaction[]
  emiLoans     Loan[]        @relation("CardEmiLoan")

  @@index([workspaceId, active])
  @@index([workspaceId, ownerUserId])
  @@index([parentAccountId])
  @@index([parentCardId])
}

model CardStatement {
  id          String               @id @default(uuid())
  workspaceId String
  workspace   Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  accountId   String
  account     Account              @relation(fields: [accountId], references: [id], onDelete: Cascade)
  periodStart DateTime             @db.Date
  periodEnd   DateTime             @db.Date
  dueDate     DateTime             @db.Date
  totalDue    Decimal              @db.Decimal(14, 2)
  paidAt      DateTime?
  // Many transfers can pay down one statement (partial payments). The
  // earlier `paidTransfer` 1-to-1 relation modelled "the single transfer
  // that closed this bill" but real-world bills are often paid in
  // instalments, so it's been replaced with this 1-to-many.
  payments    Transfer[]           @relation("StatementPayments")
  closedAt    DateTime?
  reminders   InvestmentReminder[] @relation("ReminderCardStatement")
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@unique([accountId, periodStart])
  @@index([accountId, periodEnd])
  @@index([workspaceId])
}

model Transfer {
  id            String         @id @default(uuid())
  workspaceId   String
  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId        String
  user          User           @relation("TransferAuthor", fields: [userId], references: [id], onDelete: Cascade)
  // Exactly one of fromAccountId / fromContactId is set, and exactly one of
  // toAccountId / toContactId is set. At least one side must be an account
  // (contact-to-contact transfers don't touch this workspace's books).
  fromAccountId String?
  fromAccount   Account?       @relation("TransferFrom", fields: [fromAccountId], references: [id], onDelete: Restrict)
  fromContactId String?
  fromContact   Contact?       @relation("TransferFromContact", fields: [fromContactId], references: [id], onDelete: Restrict)
  toAccountId   String?
  toAccount     Account?       @relation("TransferTo", fields: [toAccountId], references: [id], onDelete: Restrict)
  toContactId   String?
  toContact     Contact?       @relation("TransferToContact", fields: [toContactId], references: [id], onDelete: Restrict)
  amount        Decimal        @db.Decimal(14, 2)
  date          DateTime
  notes         String?
  statementId   String?
  statement     CardStatement? @relation("StatementPayments", fields: [statementId], references: [id], onDelete: SetNull)
  legs          Transaction[]  @relation("TransferLegs")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([workspaceId, date])
  @@index([fromAccountId])
  @@index([fromContactId])
  @@index([toAccountId])
  @@index([toContactId])
  @@index([statementId])
}

//
// LEDGER
//

model Category {
  id               String            @id @default(uuid())
  name             String
  types            TransactionType[]
  group            String?
  icon             String?
  isDefault        Boolean           @default(false)
  workspaceId      String?
  workspace        Workspace?        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  // Two-level hierarchy: parents have parentCategoryId = null,
  // children point at their parent. Three-level nesting is rejected
  // at the API layer, not the DB.
  parentCategoryId String?
  parent           Category?         @relation("CategoryChildren", fields: [parentCategoryId], references: [id], onDelete: SetNull)
  children         Category[]        @relation("CategoryChildren")
  transactions     Transaction[]
  createdAt        DateTime          @default(now())

  @@index([name])
  @@index([workspaceId])
  @@index([workspaceId, parentCategoryId])
}

model Transaction {
  id          String           @id @default(uuid())
  workspaceId String
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  amount      Decimal          @db.Decimal(12, 2)
  type        TransactionType
  kind        TransactionKind?
  description String
  date        DateTime
  categoryId  String?
  category    Category?        @relation(fields: [categoryId], references: [id])

  accountId String?
  account   Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  cardId    String?
  card      Card?    @relation(fields: [cardId], references: [id], onDelete: SetNull)

  workerId String?
  worker   Worker? @relation(fields: [workerId], references: [id], onDelete: SetNull)

  cropBatchId      String?
  cropBatch        CropBatch?      @relation(fields: [cropBatchId], references: [id], onDelete: SetNull)
  livestockBatchId String?
  livestockBatch   LivestockBatch? @relation(fields: [livestockBatchId], references: [id], onDelete: SetNull)

  leaseId         String?
  lease           Lease?                @relation(fields: [leaseId], references: [id], onDelete: SetNull)
  leaseScheduleId String?               @unique
  leaseSchedule   LeasePaymentSchedule? @relation("ScheduleConfirmedTxn", fields: [leaseScheduleId], references: [id], onDelete: SetNull)

  loanId String?
  loan   Loan?   @relation(fields: [loanId], references: [id], onDelete: SetNull)

  investmentId     String?
  investment       Investment?       @relation(fields: [investmentId], references: [id], onDelete: SetNull)
  investmentAction InvestmentAction?
  investmentQty    Decimal?          @db.Decimal(14, 4)
  investmentPrice  Decimal?          @db.Decimal(14, 4)
  exchangeRate     Decimal?          @db.Decimal(10, 4)

  transferId String?
  transfer   Transfer? @relation("TransferLegs", fields: [transferId], references: [id], onDelete: Cascade)

  // Refund linkage: an income-side transaction with kind=REFUND can point
  // to the original expense it reverses. SET NULL on delete so the refund
  // record survives if the original purchase is deleted.
  refundForTransactionId String?
  refundForTransaction   Transaction?  @relation("RefundOfTransaction", fields: [refundForTransactionId], references: [id], onDelete: SetNull)
  refundsReceived        Transaction[] @relation("RefundOfTransaction")

  userId          String
  user            User      @relation("TransactionAuthor", fields: [userId], references: [id], onDelete: Cascade)
  createdByUserId String?
  createdByUser   User?     @relation("TransactionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  editedByUserId  String?
  editedByUser    User?     @relation("TransactionEditedBy", fields: [editedByUserId], references: [id], onDelete: SetNull)
  editedAt        DateTime?
  editNote        String?

  beneficiaryContactId String?
  beneficiaryContact   Contact?         @relation("TransactionBeneficiary", fields: [beneficiaryContactId], references: [id], onDelete: SetNull)
  memberChargeType     MemberChargeType @default(NONE)

  claimId String?
  claim   InsuranceClaim? @relation("TransactionClaim", fields: [claimId], references: [id], onDelete: SetNull)

  vehicleId String?
  vehicle   Vehicle? @relation("VehicleTransaction", fields: [vehicleId], references: [id], onDelete: SetNull)

  // Fuel-fill metadata — only meaningful on EXPENSE transactions
  // tagged to a vehicle with category = Fuel. fuelQuantity is litres
  // or kWh or kg depending on the vehicle's fuelType at the time;
  // fuelUnit stores the symbol so historical reads stay correct even
  // if the vehicle is converted to a different fuel type later.
  // fuelOdometer is the km reading at the fill, used for mileage.
  fuelQuantity Decimal? @db.Decimal(10, 3)
  fuelUnit     String?
  fuelOdometer Int?

  hospitalizationId    String?
  hospitalization      Hospitalization?      @relation("TransactionHospitalization", fields: [hospitalizationId], references: [id], onDelete: SetNull)
  hospitalizationStage HospitalizationStage?

  // Event/Trip tagging. Multiple transactions roll up under one event
  // (e.g. "Tirupati trip"). SET NULL on event delete so transactions
  // are never destroyed when an event is removed.
  eventId String?
  event   Event?  @relation("EventTransaction", fields: [eventId], references: [id], onDelete: SetNull)

  goldForm GoldForm?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wagePayment             WagePayment?
  advanceRepayment        AdvanceRepayment?
  livestockEvent          LivestockEvent?
  feedLog                 FeedLog?
  vaccinationLog          VaccinationLog?
  memberChargeSettlements MemberChargeSettlement[]
  reminderConfirmation    InvestmentReminder?      @relation("ReminderConfirmation")
  splits                  TransactionSplit[]       @relation("TransactionSplits")

  @@index([workspaceId, date])
  @@index([workspaceId, categoryId])
  @@index([workspaceId, accountId])
  @@index([cardId])
  @@index([workerId])
  @@index([cropBatchId])
  @@index([livestockBatchId])
  @@index([leaseId])
  @@index([loanId])
  @@index([investmentId])
  @@index([transferId])
  @@index([beneficiaryContactId])
  @@index([refundForTransactionId])
  @@index([claimId])
  @@index([vehicleId])
  @@index([hospitalizationId])
  @@index([eventId])
}

model MemberCharge {
  id                   String                   @id @default(uuid())
  workspaceId          String
  workspace            Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  beneficiaryContactId String
  beneficiaryContact   Contact                  @relation(fields: [beneficiaryContactId], references: [id], onDelete: Restrict)
  amount               Decimal                  @db.Decimal(14, 2)
  settledAmount        Decimal                  @default(0) @db.Decimal(14, 2)
  status               MemberChargeStatus       @default(OUTSTANDING)
  lastSettlementAt     DateTime?
  notes                String?
  originSplit          TransactionSplit?        @relation("SplitCharge")
  settlements          MemberChargeSettlement[]
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  @@index([workspaceId, beneficiaryContactId, status])
}

// One row per contact a transaction is shared with. Replaces the legacy
// single-beneficiary model on Transaction. Each split optionally links to
// a MemberCharge (when the share is recoverable). Splits sum to <= the
// parent transaction amount; the remainder is the author's own share.
model TransactionSplit {
  id             String        @id @default(uuid())
  workspaceId    String
  workspace      Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  transactionId  String
  transaction    Transaction   @relation("TransactionSplits", fields: [transactionId], references: [id], onDelete: Cascade)
  contactId      String
  contact        Contact       @relation("ContactSplits", fields: [contactId], references: [id], onDelete: Restrict)
  amount         Decimal       @db.Decimal(14, 2)
  sharePercent   Decimal?      @db.Decimal(6, 3)
  isRecoverable  Boolean       @default(false)
  memberChargeId String?       @unique
  memberCharge   MemberCharge? @relation("SplitCharge", fields: [memberChargeId], references: [id], onDelete: SetNull)
  notes          String?
  createdAt      DateTime      @default(now())

  @@unique([transactionId, contactId])
  @@index([workspaceId, contactId])
  @@index([transactionId])
}

model MemberChargeSettlement {
