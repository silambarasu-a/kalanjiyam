model Hospitalization {
  id               String    @id @default(uuid())
  workspaceId      String
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  patientContactId String
  patientContact   Contact   @relation("HospitalizationPatient", fields: [patientContactId], references: [id], onDelete: Restrict)
  hospitalName     String
  diagnosis        String?
  admittedAt       DateTime
  dischargedAt     DateTime?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  transactions Transaction[]   @relation("TransactionHospitalization")
  claim        InsuranceClaim? @relation("HospitalizationClaim")

  @@index([workspaceId, admittedAt])
  @@index([workspaceId, patientContactId])
}

model Notification {
  id          String           @id @default(uuid())
  workspaceId String
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  /**
   * Null = workspace-wide broadcast (shown to every member).
   */
  userId      String?
  user        User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind        NotificationKind
  title       String
  body        String?
  /**
   * Deep link (e.g. /insurance/123, /medical/45) used by the inbox row.
   */
  link        String?
  readAt      DateTime?
  emailedAt   DateTime?
  /**
   * Optional source-row identifiers. Used by the cron sweep to dedupe
   * — re-running the sweep won't create duplicate rows for the same
   * (reminderId, kind) pair.
   */
  reminderId  String?
  claimId     String?
  createdAt   DateTime         @default(now())

  @@index([workspaceId, userId, readAt])
  @@index([workspaceId, createdAt])
  @@index([reminderId, kind])
}

model Vehicle {
  id             String           @id @default(uuid())
  workspaceId    String
  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  ownerContactId String
  ownerContact   Contact          @relation("VehicleOwner", fields: [ownerContactId], references: [id], onDelete: Restrict)
  kind           VehicleKind
  name           String
  make           String?
  model          String?
  year           Int?
  registrationNo String?          @unique
  // Drives the unit on fuel-fill inputs and the mileage formula.
  // Nullable so legacy rows are unaffected.
  fuelType       VehicleFuelType?
  purchaseDate   DateTime?
  purchasePrice  Decimal?         @db.Decimal(14, 2)
  odometerStart  Int?
  active         Boolean          @default(true)
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // Disposal — set when the vehicle leaves the household (sold / exchanged
  // / scrapped / gifted / written off). `active` is also flipped to false
  // at the same time; this block answers "what happened to it?". For
  // EXCHANGED disposals, `replacedById` points at the new vehicle that
  // took its place. For SOLD / GIFTED, `disposalContactId` is the buyer
  // or recipient (a workspace Contact).
  disposedAt        DateTime?
  disposalKind      VehicleDisposalKind?
  disposalAmount    Decimal?             @db.Decimal(14, 2)
  disposalContactId String?
  disposalContact   Contact?             @relation("VehicleDisposalBuyer", fields: [disposalContactId], references: [id], onDelete: SetNull)
  replacedById      String?
  replacedBy        Vehicle?             @relation("VehicleReplacement", fields: [replacedById], references: [id], onDelete: SetNull)
  replaces          Vehicle[]            @relation("VehicleReplacement")

  insurances   Investment[]      @relation("VehicleInsurance")
  loans        Loan[]            @relation("VehicleLoan")
  claims       InsuranceClaim[]  @relation("VehicleClaims")
  transactions Transaction[]     @relation("VehicleTransaction")
  documents    VehicleDocument[]

  @@index([workspaceId, active])
  @@index([workspaceId, ownerContactId])
  @@index([disposalContactId])
  @@index([replacedById])
}

model VehicleDocument {
  id                 String              @id @default(uuid())
  workspaceId        String
  workspace          Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  vehicleId          String
  vehicle            Vehicle             @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  kind               VehicleDocumentKind
  label              String? // free-form (e.g. "RC for new card", "PUC Bangalore")
  number             String? // document reference number printed on the doc
  issuedAt           DateTime?
  expiryAt           DateTime? // the date that drives renewal reminders
  notes              String?
  // Legacy inline attachment columns — kept for one release while the
  // generic Attachment model takes over. After backfill these are
  // read-only mirrors; new uploads only land in Attachment.
  attachmentKey      String?
  attachmentFilename String?
  attachmentMimeType String?
  attachmentSize     Int?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  reminders InvestmentReminder[] @relation("ReminderVehicleDocument")

  @@index([workspaceId, expiryAt])
  @@index([vehicleId])
  @@index([workspaceId, kind])
}

//
// ATTACHMENTS — polymorphic file metadata for every domain that needs
// uploads (vehicle docs, insurance policy scans, card statements,
// expense receipts, crop bills, loan documents, income proofs, …).
//
// The owner pointer (ownerKind + ownerId) is a soft FK. Referential
// integrity is enforced at the API layer (verify the parent row, then
// the workspaceId, then the S3 key prefix). Doing it this way keeps
// new owner kinds plug-and-play: add the enum value + a row in
// src/lib/attachments.ts and you're done — no schema migration needed.
//

enum AttachmentOwnerKind {
  VEHICLE_DOCUMENT
  INSURANCE_POLICY
  CARD_STATEMENT
  TRANSACTION_RECEIPT
  CROP_BATCH_BILL
  LOAN_DOCUMENT
  INCOME_PROOF
  EVENT_DOCUMENT
}

//
// EVENTS — time-bounded spending containers (trips, functions,
// festivals, projects, medical episodes). Transactions tag into an
// Event via Transaction.eventId; the Event detail page rolls them up
// across categories. Member splits reuse the existing MemberCharge
// model — no new table required.
//
enum EventKind {
  TRIP // vacations, day trips, pilgrimages
  FUNCTION // wedding, birthday, anniversary
  FESTIVAL // Diwali, Pongal, Christmas
  PROJECT // home renovation, garden setup
  MEDICAL // surgery + recovery period
  OTHER
}

model Event {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  kind        EventKind @default(TRIP)
  startedAt   DateTime
  endedAt     DateTime?
  notes       String?
  budget      Decimal?  @db.Decimal(14, 2)
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  transactions Transaction[] @relation("EventTransaction")

  @@index([workspaceId, active])
  @@index([workspaceId, startedAt])
}

model Attachment {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  ownerKind AttachmentOwnerKind
  ownerId   String

  // S3 bucket-relative key. Globally unique so a deleted-and-recreated
  // row can't collide with a stale presigned URL.
  s3Key     String  @unique
  filename  String
  mimeType  String
  sizeBytes Int
  // SHA-256 of the object body, optional. Populated by the client when
  // it can; used to detect S3-side corruption / silent re-writes.
  checksum  String?

  // Audit: WHO uploaded this, and (if applicable) who archived it.
  uploadedByUserId String
  uploadedBy       User     @relation("AttachmentUploader", fields: [uploadedByUserId], references: [id], onDelete: Restrict)
  uploadedAt       DateTime @default(now())

  archivedAt       DateTime?
  archivedByUserId String?
  archivedBy       User?     @relation("AttachmentArchiver", fields: [archivedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, ownerKind, ownerId, archivedAt])
  @@index([workspaceId, uploadedByUserId])
}

//
// WORKERS
//

model Worker {
  id                String                @id @default(uuid())
  workspaceId       String
  workspace         Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name              String
  phone             String?
  dailyRate         Decimal?              @db.Decimal(10, 2)
  settlementCadence WageSettlementCadence @default(AS_NEEDED)
  customCadenceDays Int?
  active            Boolean               @default(true)
  archivedAt        DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  attendance        Attendance[]
  wagePayments      WagePayment[]
  wageSettlements   WageSettlement[]
  advanceRepayments AdvanceRepayment[]
  transactions      Transaction[]

  @@index([workspaceId, active])
}

model Attendance {
  id                String          @id @default(uuid())
  workerId          String
  worker            Worker          @relation(fields: [workerId], references: [id], onDelete: Cascade)
  date              DateTime        @db.Date
  present           Boolean         @default(true)
  dailyRateOverride Decimal?        @db.Decimal(10, 2)
  quantity          Decimal?        @db.Decimal(8, 2)
  rate              Decimal?        @db.Decimal(10, 2)
  cropBatchId       String?
  cropBatch         CropBatch?      @relation(fields: [cropBatchId], references: [id], onDelete: SetNull)
  livestockBatchId  String?
  livestockBatch    LivestockBatch? @relation(fields: [livestockBatchId], references: [id], onDelete: SetNull)
  notes             String?
  createdAt         DateTime        @default(now())

  @@unique([workerId, date])
  @@index([workerId, date])
}

model WagePayment {
  id            String       @id @default(uuid())
  workerId      String
  worker        Worker       @relation(fields: [workerId], references: [id], onDelete: Cascade)
  amount        Decimal      @db.Decimal(12, 2)
  paidAt        DateTime
  paidByUserId  String
  paidByUser    User         @relation(fields: [paidByUserId], references: [id], onDelete: Restrict)
  isBonus       Boolean      @default(false)
  isAdvance     Boolean      @default(false)
  notes         String?
  transactionId String?      @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())

  @@index([workerId, paidAt])
}

// Money returned by a worker against a prior advance. Treated as a
// contra-expense (linked Transaction is type=EXPENSE, kind=WAGE, amount<0)
// so account balances and wage-expense rollups net automatically.
// Append-only: deletes happen via reversal entries (reversedAt + linked
// pair), never DELETE.
model AdvanceRepayment {
  id               String       @id @default(uuid())
  workspaceId      String
  workspace        Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workerId         String
  worker           Worker       @relation(fields: [workerId], references: [id], onDelete: Cascade)
  amount           Decimal      @db.Decimal(12, 2)
  receivedAt       DateTime
  receivedByUserId String
  receivedByUser   User         @relation("AdvanceRepaymentReceiver", fields: [receivedByUserId], references: [id], onDelete: Restrict)
  notes            String?
  idempotencyKey   String?
  transactionId    String?      @unique
  transaction      Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  reversedAt       DateTime?
  reversedByUserId String?
  reversedByUser   User?        @relation("AdvanceRepaymentReverser", fields: [reversedByUserId], references: [id], onDelete: SetNull)
  reversalReason   String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([workerId, idempotencyKey])
  @@index([workspaceId, receivedAt])
  @@index([workerId, receivedAt])
}

model WageSettlement {
  id              String                @id @default(uuid())
  workerId        String
  worker          Worker                @relation(fields: [workerId], references: [id], onDelete: Cascade)
  periodStart     DateTime              @db.Date
  periodEnd       DateTime              @db.Date
  cadence         WageSettlementCadence
  earnedAmount    Decimal               @db.Decimal(12, 2)
  paidAmount      Decimal               @db.Decimal(12, 2)
  amountDue       Decimal               @db.Decimal(12, 2)
  status          WageSettlementStatus  @default(PENDING)
  settledAt       DateTime?
  settledByUserId String?
  settledByUser   User?                 @relation(fields: [settledByUserId], references: [id], onDelete: SetNull)
  snapshot        Json?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@unique([workerId, periodStart, periodEnd])
  @@index([workerId, status, periodEnd])
}

//
// AUDIT
//

model AuditLog {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  action      String
  entityType  String
  entityId    String
  diff        Json?
  createdAt   DateTime  @default(now())

  @@index([workspaceId, createdAt])
  @@index([entityType, entityId])
}
